# This file is a template for you to write your own .env file with your own Telegram API key 
# You'll have to wun this command to create a .env for this proyect to work 

# copy .env.example .env

# Obviusly jou have to be in this proyect folder en your terminal

# Then in your real .env (that Git will ignore) put your apiKey and db credentials

# Telegram API — obtain from https://my.telegram.org
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+1234567890
TELEGRAM_CHAT=https://t.me/+your_invite_link_here

# PostgreSQL
POSTGRES_USER=scraper
POSTGRES_PASSWORD=change_me
POSTGRES_DB=telegram_scraper
POSTGRES_HOST=db
POSTGRES_PORT=5432
